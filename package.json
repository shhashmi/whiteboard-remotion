{
  "name": "whiteboard-remotion",
  "version": "2.0.0",
  "description": "Single-shot Remotion whiteboard video generator powered by Claude Opus 4.6",
  "scripts": {
    "generate": "ts-node src/generate.ts",
    "studio": "remotion studio src/index.tsx",
    "studio:generated": "remotion studio src/generated/index.tsx",
    "render:generated": "remotion render src/generated/index.tsx GeneratedVideo out/generated.mp4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@remotion/cli": "4.0.290",
    "@aws-sdk/client-polly": "^3.658.0",
    "dotenv": "^17.4.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3"
  }
}
